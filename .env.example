NODE_ENV=development
PORT=3000

# Local Docker Compose MongoDB.
MONGODB_URI=mongodb://codemetrics:codemetrics_password@localhost:27017/codemetrics?authSource=admin

# Heroku production should use this value as MONGODB_URI instead.
ATLAS_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/codemetrics?retryWrites=true&w=majority
