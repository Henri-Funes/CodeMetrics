NODE_ENV=development
PORT=3000

# MongoDB Atlas (required). Copy to .env and set your credentials.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/codemetrics?retryWrites=true&w=majority&appName=Cluster0

# Optional: separate database for automated tests (defaults to codemetrics_test on the same cluster).
# TEST_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/codemetrics_test?retryWrites=true&w=majority
