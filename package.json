{
  "name": "codemetrics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "install:all": "npm ci --prefix frontend && npm ci --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend && node scripts/copy-frontend-build.mjs",
    "start": "npm run start --prefix backend",
    "start:prod": "node scripts/start-prod.mjs",
    "seed": "npm run seed --prefix backend",
    "dev:docker": "docker compose up --build"
  }
}
